{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "1. Install dependencies",
      "type": "shell",
      "command": "npm install",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "2. Fix Expo Go tunnel support",
      "type": "shell",
      "command": "npm install @expo/ngrok@latest",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "3. Stop old Expo servers",
      "type": "shell",
      "command": "pkill -f \"expo start\" || true; pkill -f \"metro\" || true; rm -rf .expo",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "4. Open Auren in Expo Go - tunnel BEST",
      "type": "shell",
      "command": "npx expo start --tunnel --clear --port 8081",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "5. Open Auren in Expo Go - tunnel backup",
      "type": "shell",
      "command": "npx expo start --tunnel --port 8082",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
