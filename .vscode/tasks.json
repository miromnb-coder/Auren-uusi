{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "1. Install dependencies safely",
      "type": "shell",
      "command": "npm cache clean --force; npm install --legacy-peer-deps --no-audit --no-fund",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "2. Stop old Expo servers",
      "type": "shell",
      "command": "pkill -f \"expo start\" || true; pkill -f \"metro\" || true; rm -rf .expo",
