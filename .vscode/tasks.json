      "type": "shell",
      "command": "pkill -f \"expo start\" || true; pkill -f \"metro\" || true; rm -rf node_modules .expo package-lock.json; npm install; npm install @expo/ngrok@latest; npx expo start --tunnel --clear --port 8081",
